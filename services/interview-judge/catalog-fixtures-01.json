{
  "definitions": [
    {
      "problemId": "iv.prefix.balance-returns-to-zero",
      "version": 1,
      "ioDescription": "stdin: n, then n signed 64-bit deltas. stdout: count of non-empty prefixes whose running sum is zero.",
      "cases": [
        {"id":"visible.1","name":"returns twice","hidden":false,"category":"normal","stdin":"4\n1 -1 2 -2\n","expectedStdout":"2\n"},
        {"id":"hidden.2","name":"all zero","hidden":true,"category":"boundary","stdin":"3\n0 0 0\n","expectedStdout":"3\n"},
        {"id":"hidden.3","name":"64-bit accumulator","hidden":true,"category":"adversarial","stdin":"3\n10000000000 -10000000000 7\n","expectedStdout":"1\n"},
        {"id":"hidden.4","name":"never returns","hidden":true,"category":"normal","stdin":"5\n1 2 3 4 5\n","expectedStdout":"0\n"}
      ]
    },
    {
      "problemId": "iv.sliding.longest-window-under-budget",
      "version": 1,
      "ioDescription": "stdin: n B, then n non-negative costs. stdout: longest contiguous length with sum <= B.",
      "cases": [
        {"id":"visible.1","name":"normal window","hidden":false,"category":"normal","stdin":"5 7\n2 1 5 1 3\n","expectedStdout":"3\n"},
        {"id":"hidden.2","name":"nothing fits","hidden":true,"category":"boundary","stdin":"3 3\n4 4 4\n","expectedStdout":"0\n"},
        {"id":"hidden.3","name":"zero budget and zeros","hidden":true,"category":"boundary","stdin":"5 0\n0 0 1 0 0\n","expectedStdout":"2\n"},
        {"id":"hidden.4","name":"64-bit sum","hidden":true,"category":"adversarial","stdin":"4 3000000000\n1500000000 1500000000 1 1\n","expectedStdout":"3\n"}
      ]
    },
    {
      "problemId": "iv.heap.top-k-hot-keys",
      "version": 1,
      "ioDescription": "stdin: n k, then n whitespace-free string keys. stdout: k keys sorted by count descending, then key ascending.",
      "cases": [
        {"id":"visible.1","name":"hot keys","hidden":false,"category":"normal","stdin":"6 2\na b a c b a\n","expectedStdout":"a b\n"},
        {"id":"hidden.2","name":"ties use key order","hidden":true,"category":"boundary","stdin":"6 3\nz y x z y x\n","expectedStdout":"x y z\n"},
        {"id":"hidden.3","name":"single dominant","hidden":true,"category":"normal","stdin":"7 1\nhot cold hot hot warm hot cold\n","expectedStdout":"hot\n"},
        {"id":"hidden.4","name":"k all distinct","hidden":true,"category":"scale","stdin":"8 4\na b c d a b c d\n","expectedStdout":"a b c d\n"}
      ]
    },
    {
      "problemId": "iv.graph.service-init-order",
      "version": 1,
      "ioDescription": "stdin: n m, then m directed edges u v meaning u before v (0-based). stdout: lexicographically smallest topological order, or cycle.",
      "cases": [
        {"id":"visible.1","name":"dependency order","hidden":false,"category":"normal","stdin":"4 3\n0 1\n0 2\n2 3\n","expectedStdout":"0 1 2 3\n"},
        {"id":"hidden.2","name":"cycle","hidden":true,"category":"adversarial","stdin":"2 2\n0 1\n1 0\n","expectedStdout":"cycle\n"},
        {"id":"hidden.3","name":"disconnected deterministic","hidden":true,"category":"boundary","stdin":"5 2\n3 4\n1 2\n","expectedStdout":"0 1 2 3 4\n"},
        {"id":"hidden.4","name":"duplicate edges","hidden":true,"category":"scale","stdin":"3 3\n0 1\n0 1\n1 2\n","expectedStdout":"0 1 2\n"}
      ]
    },
    {
      "problemId": "iv.intervals.max-concurrent-maintenance",
      "version": 1,
      "ioDescription": "stdin: n, then n half-open intervals start end. stdout: maximum number active at once.",
      "cases": [
        {"id":"visible.1","name":"overlap","hidden":false,"category":"normal","stdin":"3\n1 4\n2 5\n7 9\n","expectedStdout":"2\n"},
        {"id":"hidden.2","name":"touching is not overlap","hidden":true,"category":"boundary","stdin":"3\n1 2\n2 3\n3 4\n","expectedStdout":"1\n"},
        {"id":"hidden.3","name":"identical","hidden":true,"category":"adversarial","stdin":"4\n5 10\n5 10\n5 10\n5 10\n","expectedStdout":"4\n"},
        {"id":"hidden.4","name":"nested scale","hidden":true,"category":"scale","stdin":"5\n0 100\n10 90\n20 80\n30 70\n40 60\n","expectedStdout":"5\n"}
      ]
    },
    {
      "problemId": "iv.bsearch.insert-position",
      "version": 1,
      "ioDescription": "stdin: n, sorted n values, then target t. stdout: first index with value >= t.",
      "cases": [
        {"id":"visible.1","name":"middle insertion","hidden":false,"category":"normal","stdin":"4\n1 3 5 7\n4\n","expectedStdout":"2\n"},
        {"id":"hidden.2","name":"duplicates first","hidden":true,"category":"boundary","stdin":"3\n2 2 2\n2\n","expectedStdout":"0\n"},
        {"id":"hidden.3","name":"empty","hidden":true,"category":"boundary","stdin":"0\n\n42\n","expectedStdout":"0\n"}
      ]
    },
    {
      "problemId": "iv.bsearch.rotated-min",
      "version": 1,
      "ioDescription": "stdin: n, then a rotation of a strictly increasing array. stdout: minimum value.",
      "cases": [
        {"id":"visible.1","name":"rotated","hidden":false,"category":"normal","stdin":"7\n4 5 6 7 0 1 2\n","expectedStdout":"0\n"},
        {"id":"hidden.2","name":"not rotated","hidden":true,"category":"boundary","stdin":"4\n11 13 15 17\n","expectedStdout":"11\n"},
        {"id":"hidden.3","name":"single","hidden":true,"category":"boundary","stdin":"1\n-5\n","expectedStdout":"-5\n"}
      ]
    },
    {
      "problemId": "iv.bsearch.peak-index",
      "version": 1,
      "ioDescription": "stdin: n, then values with adjacent values distinct and a unique peak. stdout: the peak index.",
      "cases": [
        {"id":"visible.1","name":"middle peak","hidden":false,"category":"normal","stdin":"3\n1 3 2\n","expectedStdout":"1\n"},
        {"id":"hidden.2","name":"increasing","hidden":true,"category":"boundary","stdin":"4\n1 2 3 4\n","expectedStdout":"3\n"},
        {"id":"hidden.3","name":"decreasing","hidden":true,"category":"boundary","stdin":"4\n4 3 2 1\n","expectedStdout":"0\n"}
      ]
    },
    {
      "problemId": "iv.bsearch.min-rate-before-deadline",
      "version": 1,
      "ioDescription": "stdin: q H, then q positive queue sizes. stdout: smallest integer rate whose summed ceil durations <= H.",
      "cases": [
        {"id":"visible.1","name":"normal rate","hidden":false,"category":"normal","stdin":"3 6\n4 5 9\n","expectedStdout":"4\n"},
        {"id":"hidden.2","name":"one queue","hidden":true,"category":"boundary","stdin":"1 2\n10\n","expectedStdout":"5\n"},
        {"id":"hidden.3","name":"deadline equals queues","hidden":true,"category":"adversarial","stdin":"4 4\n1 8 3 7\n","expectedStdout":"8\n"},
        {"id":"hidden.4","name":"large values","hidden":true,"category":"scale","stdin":"3 1000000000000\n1000000000 1000000000 1000000000\n","expectedStdout":"1\n"}
      ]
    },
    {
      "problemId": "iv.bsearch.balance-link-load",
      "version": 1,
      "ioDescription": "stdin: n m, then n non-negative demands. stdout: minimum possible maximum sum among m contiguous non-empty groups.",
      "cases": [
        {"id":"visible.1","name":"three groups","hidden":false,"category":"normal","stdin":"6 3\n2 3 1 2 4 3\n","expectedStdout":"6\n"},
        {"id":"hidden.2","name":"one per group","hidden":true,"category":"boundary","stdin":"3 3\n5 5 5\n","expectedStdout":"5\n"},
        {"id":"hidden.3","name":"one group","hidden":true,"category":"boundary","stdin":"4 1\n1 2 3 4\n","expectedStdout":"10\n"}
      ]
    }
  ]
}
