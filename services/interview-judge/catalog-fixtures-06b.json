{"definitions":[{"problemId":"iv.intervals.min-rooms","version":1,"ioDescription":"stdin: n, then n half-open meeting intervals start end. stdout: minimum rooms.","cases":[{"id":"visible.1","name":"overlap","hidden":false,"category":"normal","stdin":"3\n0 30\n5 10\n15 20\n","expectedStdout":"2\n"},{"id":"hidden.2","name":"touching reuse","hidden":true,"category":"boundary","stdin":"3\n0 5\n5 10\n10 15\n","expectedStdout":"1\n"},{"id":"hidden.3","name":"all overlap","hidden":true,"category":"adversarial","stdin":"4\n1 10\n2 9\n3 8\n4 7\n","expectedStdout":"4\n"}]},{"problemId":"iv.intervals.max-non-overlapping","version":1,"ioDescription":"stdin: n, then n half-open intervals. stdout: maximum number of mutually non-overlapping intervals; touching is allowed.","cases":[{"id":"visible.1","name":"activity selection","hidden":false,"category":"normal","stdin":"4\n1 3\n2 5\n4 7\n6 9\n","expectedStdout":"2\n"},{"id":"hidden.2","name":"all compatible","hidden":true,"category":"boundary","stdin":"3\n1 2\n2 3\n3 4\n","expectedStdout":"3\n"},{"id":"hidden.3","name":"same end","hidden":true,"category":"adversarial","stdin":"4\n0 5\n1 5\n2 5\n5 6\n","expectedStdout":"2\n"}]},{"problemId":"iv.cpp.iterator-invalidation","version":1,"ioDescription":"stdin: n, then n integers. Safely append double of each even value from the original n elements exactly once. stdout: final vector.","cases":[{"id":"visible.1","name":"append evens","hidden":false,"category":"normal","stdin":"4\n2 3 4 5\n","expectedStdout":"2 3 4 5 4 8\n"},{"id":"hidden.2","name":"none even","hidden":true,"category":"boundary","stdin":"3\n1 3 5\n","expectedStdout":"1 3 5\n"},{"id":"hidden.3","name":"all even","hidden":true,"category":"adversarial","stdin":"3\n0 2 -4\n","expectedStdout":"0 2 -4 0 4 -8\n"},{"id":"hidden.4","name":"empty","hidden":true,"category":"boundary","stdin":"0\n","expectedStdout":"\n"}]},{"problemId":"iv.cpp.dangling-reference","version":1,"ioDescription":"stdin: integer id. Implement makeLabel safely by returning std::string by value. stdout: node-<id>.","cases":[{"id":"visible.1","name":"positive id","hidden":false,"category":"normal","stdin":"42\n","expectedStdout":"node-42\n"},{"id":"hidden.2","name":"zero","hidden":true,"category":"boundary","stdin":"0\n","expectedStdout":"node-0\n"},{"id":"hidden.3","name":"negative","hidden":true,"category":"boundary","stdin":"-7\n","expectedStdout":"node--7\n"},{"id":"hidden.4","name":"large","hidden":true,"category":"scale","stdin":"2147483647\n","expectedStdout":"node-2147483647\n"}]},{"problemId":"iv.cpp.missing-virtual-destructor","version":1,"ioDescription":"stdin: n. Create and destroy n Derived objects through owning Base pointers with a virtual destructor. stdout: DB repeated n times (Derived then Base destructor).","cases":[{"id":"visible.1","name":"two objects","hidden":false,"category":"normal","stdin":"2\n","expectedStdout":"DBDB\n"},{"id":"hidden.2","name":"none","hidden":true,"category":"boundary","stdin":"0\n","expectedStdout":"\n"},{"id":"hidden.3","name":"one","hidden":true,"category":"boundary","stdin":"1\n","expectedStdout":"DB\n"},{"id":"hidden.4","name":"several","hidden":true,"category":"scale","stdin":"5\n","expectedStdout":"DBDBDBDBDB\n"}]}]}
