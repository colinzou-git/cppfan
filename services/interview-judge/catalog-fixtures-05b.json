{"definitions":[{"problemId":"iv.prefix.range-sum-queries","version":1,"ioDescription":"stdin: n q, n integers, then q inclusive 0-based ranges l r. stdout: one sum per line.","cases":[{"id":"visible.1","name":"queries","hidden":false,"category":"normal","stdin":"5 3\n2 4 1 7 3\n0 2\n1 3\n4 4\n","expectedStdout":"7\n12\n3\n"},{"id":"hidden.2","name":"full range","hidden":true,"category":"boundary","stdin":"3 1\n-1 2 5\n0 2\n","expectedStdout":"6\n"},{"id":"hidden.3","name":"64-bit","hidden":true,"category":"adversarial","stdin":"2 1\n3000000000 3000000000\n0 1\n","expectedStdout":"6000000000\n"}]},{"problemId":"iv.prefix.subarrays-sum-k","version":1,"ioDescription":"stdin: n k, then n signed integers. stdout: count of contiguous subarrays summing to k.","cases":[{"id":"visible.1","name":"normal count","hidden":false,"category":"normal","stdin":"3 2\n1 1 1\n","expectedStdout":"2\n"},{"id":"hidden.2","name":"zeros","hidden":true,"category":"adversarial","stdin":"3 0\n0 0 0\n","expectedStdout":"6\n"},{"id":"hidden.3","name":"negative numbers","hidden":true,"category":"boundary","stdin":"5 0\n1 -1 1 -1 1\n","expectedStdout":"6\n"}]},{"problemId":"iv.hash.longest-consecutive-run","version":1,"ioDescription":"stdin: n, then n integers. stdout: length of longest consecutive-value run.","cases":[{"id":"visible.1","name":"normal","hidden":false,"category":"normal","stdin":"6\n100 4 200 1 3 2\n","expectedStdout":"4\n"},{"id":"hidden.2","name":"duplicates","hidden":true,"category":"boundary","stdin":"6\n1 2 2 3 3 4\n","expectedStdout":"4\n"},{"id":"hidden.3","name":"empty","hidden":true,"category":"boundary","stdin":"0\n","expectedStdout":"0\n"}]},{"problemId":"iv.prefix.longest-equal-binary","version":1,"ioDescription":"stdin: n, then n values each 0 or 1. stdout: longest contiguous length with equal numbers of 0 and 1.","cases":[{"id":"visible.1","name":"normal","hidden":false,"category":"normal","stdin":"5\n0 1 0 1 1\n","expectedStdout":"4\n"},{"id":"hidden.2","name":"all same","hidden":true,"category":"boundary","stdin":"4\n1 1 1 1\n","expectedStdout":"0\n"},{"id":"hidden.3","name":"whole array","hidden":true,"category":"adversarial","stdin":"6\n0 0 1 0 1 1\n","expectedStdout":"6\n"}]},{"problemId":"iv.twoptr.pair-sum-sorted","version":1,"ioDescription":"stdin: n target, then sorted integers. stdout: 0-based indices of a pair summing to target, or -1 -1.","cases":[{"id":"visible.1","name":"normal pair","hidden":false,"category":"normal","stdin":"5 9\n1 2 4 7 10\n","expectedStdout":"1 3\n"},{"id":"hidden.2","name":"endpoints","hidden":true,"category":"boundary","stdin":"4 11\n1 3 5 10\n","expectedStdout":"0 3\n"},{"id":"hidden.3","name":"none","hidden":true,"category":"boundary","stdin":"3 100\n1 2 3\n","expectedStdout":"-1 -1\n"}]}]}
