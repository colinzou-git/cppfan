{"definitions":[{"problemId":"iv.twoptr.is-palindrome","version":1,"ioDescription":"stdin: one text line. Ignore non-alphanumeric characters and case. stdout: true or false.","cases":[{"id":"visible.1","name":"phrase","hidden":false,"category":"normal","stdin":"A man, a plan, a canal: Panama\n","expectedStdout":"true\n"},{"id":"hidden.2","name":"not palindrome","hidden":true,"category":"normal","stdin":"race a car\n","expectedStdout":"false\n"},{"id":"hidden.3","name":"no alphanumeric","hidden":true,"category":"boundary","stdin":"!!!\n","expectedStdout":"true\n"}]},{"problemId":"iv.sliding.longest-distinct","version":1,"ioDescription":"stdin: one text line. stdout: length of longest substring with no repeated byte characters.","cases":[{"id":"visible.1","name":"normal","hidden":false,"category":"normal","stdin":"abcabcbb\n","expectedStdout":"3\n"},{"id":"hidden.2","name":"all same","hidden":true,"category":"boundary","stdin":"bbbbb\n","expectedStdout":"1\n"},{"id":"hidden.3","name":"empty","hidden":true,"category":"boundary","stdin":"\n","expectedStdout":"0\n"}]},{"problemId":"iv.twoptr.most-water","version":1,"ioDescription":"stdin: n, then n non-negative heights. stdout: maximum area between two lines.","cases":[{"id":"visible.1","name":"classic","hidden":false,"category":"normal","stdin":"9\n1 8 6 2 5 4 8 3 7\n","expectedStdout":"49\n"},{"id":"hidden.2","name":"two lines","hidden":true,"category":"boundary","stdin":"2\n1 1\n","expectedStdout":"1\n"},{"id":"hidden.3","name":"large area","hidden":true,"category":"adversarial","stdin":"3\n2000000000 0 2000000000\n","expectedStdout":"4000000000\n"}]},{"problemId":"iv.intervals.merge-overlapping","version":1,"ioDescription":"stdin: n, then n closed intervals start end. Touching intervals merge. stdout: count, then merged intervals.","cases":[{"id":"visible.1","name":"normal merge","hidden":false,"category":"normal","stdin":"4\n1 3\n2 6\n8 10\n15 18\n","expectedStdout":"3\n1 6\n8 10\n15 18\n"},{"id":"hidden.2","name":"touching","hidden":true,"category":"boundary","stdin":"3\n1 2\n2 3\n5 5\n","expectedStdout":"2\n1 3\n5 5\n"},{"id":"hidden.3","name":"nested","hidden":true,"category":"adversarial","stdin":"3\n1 10\n2 3\n4 5\n","expectedStdout":"1\n1 10\n"}]},{"problemId":"iv.intervals.insert","version":1,"ioDescription":"stdin: n disjoint sorted closed intervals, then new start end. Touching intervals merge. stdout: count, then result intervals.","cases":[{"id":"visible.1","name":"insert and merge","hidden":false,"category":"normal","stdin":"2\n1 3\n6 9\n2 5\n","expectedStdout":"2\n1 5\n6 9\n"},{"id":"hidden.2","name":"append","hidden":true,"category":"boundary","stdin":"2\n1 2\n3 4\n6 7\n","expectedStdout":"3\n1 2\n3 4\n6 7\n"},{"id":"hidden.3","name":"cover all","hidden":true,"category":"adversarial","stdin":"3\n1 2\n4 5\n7 9\n0 10\n","expectedStdout":"1\n0 10\n"}]}]}
