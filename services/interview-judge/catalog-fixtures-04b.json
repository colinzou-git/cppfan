{"definitions":[{"problemId":"iv.graph.has-directed-cycle","version":1,"ioDescription":"stdin: n m, then m directed edges. stdout: true iff a directed cycle exists.","cases":[{"id":"visible.1","name":"cycle","hidden":false,"category":"normal","stdin":"4 4\n0 1\n1 2\n2 0\n2 3\n","expectedStdout":"true\n"},{"id":"hidden.2","name":"dag","hidden":true,"category":"boundary","stdin":"4 3\n0 1\n0 2\n2 3\n","expectedStdout":"false\n"},{"id":"hidden.3","name":"single-vertex edge","hidden":true,"category":"adversarial","stdin":"2 1\n1 1\n","expectedStdout":"true\n"}]},{"problemId":"iv.graph.cheapest-route","version":1,"ioDescription":"stdin: n m s t, then m directed edges u v non-negative-weight. stdout: cheapest cost or -1.","cases":[{"id":"visible.1","name":"dijkstra route","hidden":false,"category":"normal","stdin":"5 6 0 4\n0 1 4\n0 2 1\n2 1 2\n1 3 1\n2 3 5\n3 4 3\n","expectedStdout":"7\n"},{"id":"hidden.2","name":"unreachable","hidden":true,"category":"boundary","stdin":"3 1 0 2\n0 1 5\n","expectedStdout":"-1\n"},{"id":"hidden.3","name":"large weights","hidden":true,"category":"adversarial","stdin":"3 3 0 2\n0 1 3000000000\n1 2 3000000000\n0 2 7000000000\n","expectedStdout":"6000000000\n"},{"id":"hidden.4","name":"zero edge","hidden":true,"category":"scale","stdin":"4 5 0 3\n0 1 0\n1 2 0\n2 3 0\n0 2 5\n1 3 8\n","expectedStdout":"0\n"}]},{"problemId":"iv.graph.min-spanning-cost","version":1,"ioDescription":"stdin: n m, then m undirected weighted edges. stdout: MST cost, or -1 if disconnected.","cases":[{"id":"visible.1","name":"kruskal","hidden":false,"category":"normal","stdin":"4 5\n0 1 1\n1 2 2\n2 3 3\n0 3 10\n0 2 4\n","expectedStdout":"6\n"},{"id":"hidden.2","name":"disconnected","hidden":true,"category":"boundary","stdin":"4 2\n0 1 1\n2 3 1\n","expectedStdout":"-1\n"},{"id":"hidden.3","name":"negative weights","hidden":true,"category":"adversarial","stdin":"3 3\n0 1 -5\n1 2 2\n0 2 10\n","expectedStdout":"-3\n"}]},{"problemId":"iv.heap.kth-largest-stream","version":1,"ioDescription":"stdin: k n, then n values. stdout: kth-largest after each insertion once at least k values exist, space-separated.","cases":[{"id":"visible.1","name":"running kth","hidden":false,"category":"normal","stdin":"3 6\n4 5 8 2 10 9\n","expectedStdout":"4 4 5 8\n"},{"id":"hidden.2","name":"k one","hidden":true,"category":"boundary","stdin":"1 4\n-2 -1 -5 3\n","expectedStdout":"-2 -1 -1 3\n"},{"id":"hidden.3","name":"duplicates","hidden":true,"category":"adversarial","stdin":"2 5\n5 5 5 4 6\n","expectedStdout":"5 5 5 5\n"}]},{"problemId":"iv.heap.merge-k-sorted","version":1,"ioDescription":"stdin: k, followed by k lines: length then sorted values. stdout: all values merged.","cases":[{"id":"visible.1","name":"three lists","hidden":false,"category":"normal","stdin":"3\n3 1 4 7\n2 2 8\n3 0 5 9\n","expectedStdout":"0 1 2 4 5 7 8 9\n"},{"id":"hidden.2","name":"empty lists","hidden":true,"category":"boundary","stdin":"3\n0\n2 1 2\n0\n","expectedStdout":"1 2\n"},{"id":"hidden.3","name":"duplicates","hidden":true,"category":"adversarial","stdin":"2\n3 1 1 2\n3 1 2 2\n","expectedStdout":"1 1 1 2 2 2\n"}]}]}
