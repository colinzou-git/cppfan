{
  "definitions": [
    {
      "problemId": "iv.stack.balanced-delimiters",
      "version": 1,
      "ioDescription": "stdin: one line containing only ()[]{} characters (possibly empty). stdout: true or false.",
      "cases": [
        {"id":"visible.1","name":"balanced","hidden":false,"category":"normal","stdin":"()[]{}\n","expectedStdout":"true\n"},
        {"id":"hidden.2","name":"wrong nesting","hidden":true,"category":"adversarial","stdin":"([)]\n","expectedStdout":"false\n"},
        {"id":"hidden.3","name":"empty","hidden":true,"category":"boundary","stdin":"\n","expectedStdout":"true\n"}
      ]
    },
    {
      "problemId": "iv.stack.steps-to-higher-load",
      "version": 1,
      "ioDescription": "stdin: n, then n integer readings. stdout: distances to the next strictly higher reading.",
      "cases": [
        {"id":"visible.1","name":"mixed readings","hidden":false,"category":"normal","stdin":"5\n3 1 4 1 5\n","expectedStdout":"2 1 2 1 0\n"},
        {"id":"hidden.2","name":"decreasing","hidden":true,"category":"boundary","stdin":"3\n5 4 3\n","expectedStdout":"0 0 0\n"},
        {"id":"hidden.3","name":"equals not higher","hidden":true,"category":"adversarial","stdin":"5\n2 2 3 3 4\n","expectedStdout":"2 1 2 1 0\n"}
      ]
    },
    {
      "problemId": "iv.stack.min-stack-design",
      "version": 1,
      "ioDescription": "stdin: q followed by q operations: push x, pop, top, or min. stdout: one line for each top/min query.",
      "cases": [
        {"id":"visible.1","name":"basic operations","hidden":false,"category":"normal","stdin":"9\npush 5\npush 2\nmin\npush 7\nmin\npop\nmin\npop\nmin\n","expectedStdout":"2\n2\n2\n5\n"},
        {"id":"hidden.2","name":"duplicate minima","hidden":true,"category":"boundary","stdin":"7\npush 3\npush 1\npush 1\nmin\npop\nmin\ntop\n","expectedStdout":"1\n1\n1\n"},
        {"id":"hidden.3","name":"single item","hidden":true,"category":"boundary","stdin":"3\npush -4\ntop\nmin\n","expectedStdout":"-4\n-4\n"}
      ]
    },
    {
      "problemId": "iv.queue.window-peak-load",
      "version": 1,
      "ioDescription": "stdin: n k, then n readings. stdout: maximum for every contiguous window of length k.",
      "cases": [
        {"id":"visible.1","name":"classic","hidden":false,"category":"normal","stdin":"8 3\n1 3 -1 -3 5 3 6 7\n","expectedStdout":"3 3 5 5 6 7\n"},
        {"id":"hidden.2","name":"k one","hidden":true,"category":"boundary","stdin":"4 1\n4 2 1 9\n","expectedStdout":"4 2 1 9\n"},
        {"id":"hidden.3","name":"decreasing","hidden":true,"category":"adversarial","stdin":"5 3\n5 4 3 2 1\n","expectedStdout":"5 4 3\n"}
      ]
    },
    {
      "problemId": "iv.dp.ways-to-reach-step",
      "version": 1,
      "ioDescription": "stdin: n (0..90). stdout: number of ordered 1/2-step ways, with n=0 yielding 1.",
      "cases": [
        {"id":"visible.1","name":"four steps","hidden":false,"category":"normal","stdin":"4\n","expectedStdout":"5\n"},
        {"id":"hidden.2","name":"zero","hidden":true,"category":"boundary","stdin":"0\n","expectedStdout":"1\n"},
        {"id":"hidden.3","name":"large 64-bit","hidden":true,"category":"scale","stdin":"50\n","expectedStdout":"20365011074\n"}
      ]
    },
    {
      "problemId": "iv.dp.max-contiguous-flow",
      "version": 1,
      "ioDescription": "stdin: n, then n signed readings. stdout: largest non-empty contiguous sum.",
      "cases": [
        {"id":"visible.1","name":"mixed","hidden":false,"category":"normal","stdin":"9\n-2 1 -3 4 -1 2 1 -5 4\n","expectedStdout":"6\n"},
        {"id":"hidden.2","name":"all negative","hidden":true,"category":"boundary","stdin":"3\n-3 -1 -2\n","expectedStdout":"-1\n"},
        {"id":"hidden.3","name":"64-bit sum","hidden":true,"category":"adversarial","stdin":"3\n2000000000 2000000000 -1\n","expectedStdout":"4000000000\n"}
      ]
    },
    {
      "problemId": "iv.dp.fewest-coins",
      "version": 1,
      "ioDescription": "stdin: c amount, then c positive denominations. stdout: fewest coins, or -1.",
      "cases": [
        {"id":"visible.1","name":"normal","hidden":false,"category":"normal","stdin":"3 6\n1 3 4\n","expectedStdout":"2\n"},
        {"id":"hidden.2","name":"impossible","hidden":true,"category":"boundary","stdin":"1 3\n2\n","expectedStdout":"-1\n"},
        {"id":"hidden.3","name":"zero amount","hidden":true,"category":"boundary","stdin":"3 0\n2 5 7\n","expectedStdout":"0\n"},
        {"id":"hidden.4","name":"non-greedy optimum","hidden":true,"category":"adversarial","stdin":"3 10\n1 6 7\n","expectedStdout":"4\n"}
      ]
    },
    {
      "problemId": "iv.backtracking.subset-sum-count",
      "version": 1,
      "ioDescription": "stdin: n target, then n distinct positive part sizes. stdout: number of subsets summing to target.",
      "cases": [
        {"id":"visible.1","name":"two subsets","hidden":false,"category":"normal","stdin":"4 7\n2 3 5 7\n","expectedStdout":"2\n"},
        {"id":"hidden.2","name":"empty subset","hidden":true,"category":"boundary","stdin":"3 0\n1 2 3\n","expectedStdout":"1\n"},
        {"id":"hidden.3","name":"none","hidden":true,"category":"boundary","stdin":"3 100\n1 2 3\n","expectedStdout":"0\n"}
      ]
    },
    {
      "problemId": "iv.dsu.count-clusters",
      "version": 1,
      "ioDescription": "stdin: n m, then m undirected edges. stdout: number of connected components.",
      "cases": [
        {"id":"visible.1","name":"three clusters","hidden":false,"category":"normal","stdin":"6 3\n0 1\n1 2\n3 4\n","expectedStdout":"3\n"},
        {"id":"hidden.2","name":"no edges","hidden":true,"category":"boundary","stdin":"4 0\n","expectedStdout":"4\n"},
        {"id":"hidden.3","name":"duplicates and self","hidden":true,"category":"adversarial","stdin":"3 4\n0 1\n0 1\n1 1\n1 2\n","expectedStdout":"1\n"}
      ]
    },
    {
      "problemId": "iv.dsu.redundant-link",
      "version": 1,
      "ioDescription": "stdin: n m, then undirected edges in arrival order. stdout: first edge that joins already-connected vertices, or none.",
      "cases": [
        {"id":"visible.1","name":"cycle closer","hidden":false,"category":"normal","stdin":"3 3\n0 1\n1 2\n0 2\n","expectedStdout":"0 2\n"},
        {"id":"hidden.2","name":"no cycle","hidden":true,"category":"boundary","stdin":"4 3\n0 1\n1 2\n2 3\n","expectedStdout":"none\n"},
        {"id":"hidden.3","name":"duplicate edge","hidden":true,"category":"adversarial","stdin":"2 2\n0 1\n0 1\n","expectedStdout":"0 1\n"}
      ]
    }
  ]
}
