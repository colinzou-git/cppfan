{"definitions":[{"problemId":"iv.heap.k-closest-points","version":1,"ioDescription":"stdin: n k, then n integer points x y. stdout: chosen points sorted by distance squared, x, then y; one point per line.","cases":[{"id":"visible.1","name":"closest two","hidden":false,"category":"normal","stdin":"4 2\n1 3\n-2 2\n2 -2\n5 8\n","expectedStdout":"-2 2\n2 -2\n"},{"id":"hidden.2","name":"k all","hidden":true,"category":"boundary","stdin":"2 2\n0 1\n0 0\n","expectedStdout":"0 0\n0 1\n"},{"id":"hidden.3","name":"tie order","hidden":true,"category":"adversarial","stdin":"4 3\n1 0\n-1 0\n0 1\n0 -1\n","expectedStdout":"-1 0\n0 -1\n0 1\n"},{"id":"hidden.4","name":"large coordinates","hidden":true,"category":"scale","stdin":"3 1\n1000000000 1000000000\n1 1\n-2 -2\n","expectedStdout":"1 1\n"}]},{"problemId":"iv.heap.running-median","version":1,"ioDescription":"stdin: n, then n integers. stdout: median after each insertion, formatted as integer or x.5.","cases":[{"id":"visible.1","name":"mixed","hidden":false,"category":"normal","stdin":"5\n2 1 5 7 2\n","expectedStdout":"2 1.5 2 3.5 2\n"},{"id":"hidden.2","name":"negative","hidden":true,"category":"boundary","stdin":"4\n-5 -1 -3 -2\n","expectedStdout":"-5 -3 -3 -2.5\n"},{"id":"hidden.3","name":"large average","hidden":true,"category":"adversarial","stdin":"2\n2000000000 2000000000\n","expectedStdout":"2000000000 2000000000\n"}]},{"problemId":"iv.heap.task-cooldown","version":1,"ioDescription":"stdin: n cooldown, then n single-character task labels. stdout: minimum time slots needed.","cases":[{"id":"visible.1","name":"classic","hidden":false,"category":"normal","stdin":"6 2\nA A A B B B\n","expectedStdout":"8\n"},{"id":"hidden.2","name":"no cooldown","hidden":true,"category":"boundary","stdin":"4 0\nA A B C\n","expectedStdout":"4\n"},{"id":"hidden.3","name":"one task type","hidden":true,"category":"adversarial","stdin":"4 3\nA A A A\n","expectedStdout":"13\n"}]},{"problemId":"iv.hash.pair-sums-to-target","version":1,"ioDescription":"stdin: n target, then n integers. stdout: first pair of indices discovered by left-to-right hash-map scan, or -1 -1.","cases":[{"id":"visible.1","name":"normal pair","hidden":false,"category":"normal","stdin":"4 9\n2 7 11 15\n","expectedStdout":"0 1\n"},{"id":"hidden.2","name":"duplicates","hidden":true,"category":"boundary","stdin":"3 6\n3 3 4\n","expectedStdout":"0 1\n"},{"id":"hidden.3","name":"no pair","hidden":true,"category":"boundary","stdin":"3 100\n1 2 3\n","expectedStdout":"-1 -1\n"}]},{"problemId":"iv.hash.most-frequent","version":1,"ioDescription":"stdin: n, then n integers. stdout: most frequent value; ties choose the smaller value.","cases":[{"id":"visible.1","name":"normal frequency","hidden":false,"category":"normal","stdin":"7\n2 1 2 3 1 2 1\n","expectedStdout":"1\n"},{"id":"hidden.2","name":"single","hidden":true,"category":"boundary","stdin":"1\n-4\n","expectedStdout":"-4\n"},{"id":"hidden.3","name":"tie","hidden":true,"category":"adversarial","stdin":"4\n9 8 9 8\n","expectedStdout":"8\n"}]}]}
