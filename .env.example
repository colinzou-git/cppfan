# Supabase
# Create a Supabase project, then copy these values from Project Settings -> API.
#
# Leave these blank until you have real Supabase values.
# Do NOT use placeholders like YOUR_PROJECT_ID here in .env.local, because
# Supabase requires NEXT_PUBLIC_SUPABASE_URL to be a real http/https URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback if your Supabase dashboard only shows anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App metadata
# Local browser usage:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=cppFan

# Optional future integrations
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SENTRY_AUTH_TOKEN=
