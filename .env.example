# Supabase
# Create a Supabase project, then copy these values from Project Settings -> API.
#
# Supabase now recommends publishable keys for browser/client usage.
# If your project still shows a legacy anon key, NEXT_PUBLIC_SUPABASE_ANON_KEY
# remains supported by this scaffold as a fallback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App metadata
# Use http://127.0.0.1:3000 if you run Playwright against 127.0.0.1.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=cppFan

# Optional future integrations
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SENTRY_AUTH_TOKEN=
