# Supabase
# Create a Supabase project, then copy these values from Project Settings -> API.
#
# Leave these blank until you have real Supabase values.
# Do NOT use placeholders like YOUR_PROJECT_ID here in .env.local, because
# Supabase requires NEXT_PUBLIC_SUPABASE_URL to be a real http/https URL.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy fallback if your Supabase dashboard only shows anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App metadata
# Local browser usage:
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=cppFan

# AI Chat
AI_CHAT_ENABLED=false
AI_PROVIDER=groq
AI_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=
AI_DAILY_REQUEST_LIMIT=50
AI_DAILY_INPUT_CHAR_LIMIT=250000
AI_MINUTE_REQUEST_LIMIT=6
AI_REQUEST_TIMEOUT_MS=45000
AI_MAX_OUTPUT_TOKENS=900

# Deterministic local/CI provider:
# AI_CHAT_ENABLED=true
# AI_PROVIDER=fake

# Optional future integrations
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SENTRY_AUTH_TOKEN=
