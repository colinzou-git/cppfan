{
  "id": "strings-anagram-check",
  "title": "Strings: anagram check",
  "skill_ids": ["dsa.strings.char_frequency", "dsa.strings.hashing"],
  "difficulty": "beginner",
  "estimated_minutes": 20,
  "editable_files": ["anagram.hpp"],
  "build_command": "g++ -std=c++20 -Wall -Wextra -Wpedantic -fsanitize=address,undefined -I exercises/_harness -I exercises/strings-anagram-check/work exercises/strings-anagram-check/tests/tests.cpp -o exercises/strings-anagram-check/work/run",
  "test_command": "exercises/strings-anagram-check/work/run",
  "required_tests": ["test_basic_anagrams", "test_not_anagrams", "test_ignores_case", "test_ignores_spaces", "test_empty_and_spaces", "test_counts_matter"],
  "hints": [
    "Tally each character's frequency for the first string.",
    "Subtract the second string's characters from the same tally.",
    "Skip spaces and lowercase letters before counting; the strings are anagrams when every count returns to zero."
  ],
  "project_lab": "text-statistics-analyzer"
}
