  "build_command": "g++ -std=c++20 -Wall -Wextra -Wpedantic -fsanitize=address,undefined -I exercises/_harness -I exercises/greedy-jump-game/work exercises/greedy-jump-game/tests/tests.cpp -o exercises/greedy-jump-game/work/run",
